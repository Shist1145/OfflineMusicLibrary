<Window x:Class="OfflineMusicLibrary.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OfflineMusicLibrary"
        Title="设置与个性化" Width="1020" Height="760" MinWidth="900" MinHeight="650"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,14" />
        </Style>
        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="68" />
        </Grid.RowDefinitions>

        <TabControl Margin="18,14,18,0" Background="White" BorderBrush="{StaticResource LineBrush}">
            <TabItem Header="常规">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,22">
                        <TextBlock Text="外观与字体" Style="{StaticResource SectionTitleStyle}" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="52" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="界面字体" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="UiFontCombo" Grid.Column="1" Width="330" HorizontalAlignment="Left"
                                      IsEditable="True" IsTextSearchEnabled="True" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="列出 Windows 已安装字体；保存后主界面立即应用。"
                                       Style="{StaticResource HintStyle}" />
                        </Grid>

                        <Separator />
                        <TextBlock Text="启动与关闭" Style="{StaticResource SectionTitleStyle}" Margin="0,22,0,14" />
                        <CheckBox x:Name="RunAtStartupCheckBox" Content="开机自动运行" Margin="0,0,0,12" />
                        <CheckBox x:Name="StartMinimizedCheckBox" Content="启动后最小化展示" Margin="0,0,0,18" />
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="关闭主窗口" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="CloseBehaviorCombo" Grid.Column="1" Width="260" HorizontalAlignment="Left">
                                <ComboBoxItem Content="退出程序" Tag="Exit" />
                                <ComboBoxItem Content="最小化到系统托盘" Tag="MinimizeToTray" />
                                <ComboBoxItem Content="最小化到任务栏" Tag="Minimize" />
                            </ComboBox>
                        </Grid>

                        <Separator />
                        <TextBlock Text="定时关闭" Style="{StaticResource SectionTitleStyle}" Margin="0,22,0,14" />
                        <CheckBox x:Name="AutoCloseCheckBox" Content="开启定时关闭播放器" Margin="0,0,0,14" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsChecked, ElementName=AutoCloseCheckBox}">
                            <TextBlock Text="剩余关闭时间" VerticalAlignment="Center" Margin="0,0,14,0" />
                            <ComboBox x:Name="AutoCloseHoursCombo" Width="110" />
                            <TextBlock Text="小时" VerticalAlignment="Center" Margin="8,0,18,0" />
                            <ComboBox x:Name="AutoCloseMinutesCombo" Width="110" />
                            <TextBlock Text="分钟" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="播放">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,22">
                        <TextBlock Text="音量" Style="{StaticResource SectionTitleStyle}" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="默认音量" Style="{StaticResource SettingLabelStyle}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="DefaultVolumeSlider" Width="330" Minimum="0" Maximum="100" TickFrequency="5"
                                        IsSnapToTickEnabled="True" ValueChanged="DefaultVolumeSlider_ValueChanged" />
                                <TextBlock x:Name="DefaultVolumeText" Width="60" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <Separator />
                        <TextBlock Text="启动播放" Style="{StaticResource SectionTitleStyle}" Margin="0,22,0,14" />
                        <CheckBox x:Name="AutoPlayOnStartupCheckBox" Content="程序启动时自动播放上次歌曲" Margin="0,0,0,12" />
                        <CheckBox x:Name="RememberPlaybackProgressCheckBox" Content="记住上次歌曲和播放进度" Margin="0,0,0,24" />

                        <Separator />
                        <TextBlock Text="播放列表行为" Style="{StaticResource SectionTitleStyle}" Margin="0,22,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="双击歌曲时" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="DoubleClickQueueModeCombo" Grid.Column="1" Width="420" HorizontalAlignment="Left">
                                <ComboBoxItem Content="用当前歌曲所在列表替换播放队列" Tag="Replace" />
                                <ComboBoxItem Content="只把当前歌曲加入播放队列并播放" Tag="Append" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="快捷键">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,22">
                        <TextBlock Text="快捷键" Style="{StaticResource SectionTitleStyle}" />
                        <CheckBox x:Name="GlobalHotkeysCheckBox" Content="启用全局快捷键（播放器在后台时也能响应）" Margin="0,0,0,12" />
                        <CheckBox x:Name="SystemMediaKeysCheckBox" Content="使用系统媒体键（播放/暂停、上一首、下一首）" Margin="0,0,0,20" />

                        <Border Background="#F5F8F7" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="230" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="38" />
                                    <RowDefinition Height="38" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="功能" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="窗口内快捷键" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="全局快捷键" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Text="播放 / 暂停" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl + P / Space" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Ctrl + Alt + P" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Text="上一首" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Ctrl + Left" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Ctrl + Alt + Left" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="3" Text="下一首" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Ctrl + Right" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Ctrl + Alt + Right" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="4" Text="音量加 / 减" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="Ctrl + Up / Down" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="Ctrl + Alt + Up / Down" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="5" Text="打开 / 关闭桌面歌词" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="Ctrl + D" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="Ctrl + Alt + D" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="6" Text="收藏歌曲 / 最小化" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="Ctrl + L / Ctrl + M" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="Ctrl + Alt + L / M" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="音视频">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="28,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60" />
                            <RowDefinition Height="60" />
                            <RowDefinition Height="60" />
                            <RowDefinition Height="60" />
                            <RowDefinition Height="60" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="音频输出后端" Style="{StaticResource SettingLabelStyle}" />
                        <ComboBox x:Name="AudioBackendCombo" Grid.Column="1" Width="300" HorizontalAlignment="Left">
                            <ComboBoxItem Content="DirectSound（稳定优先，推荐）" Tag="DirectSound" />
                            <ComboBoxItem Content="自动选择" Tag="Auto" />
                            <ComboBoxItem Content="WASAPI" Tag="Wasapi" />
                            <ComboBoxItem Content="WaveOut（兼容模式）" Tag="WaveOut" />
                        </ComboBox>
                        <TextBlock Grid.Row="1" Text="硬件加速解码" Style="{StaticResource SettingLabelStyle}" />
                        <ComboBox x:Name="HardwareDecodingCombo" Grid.Row="1" Grid.Column="1" Width="300" HorizontalAlignment="Left">
                            <ComboBoxItem Content="自动（推荐）" Tag="Auto" />
                            <ComboBoxItem Content="Direct3D 11 VA" Tag="D3D11VA" />
                            <ComboBoxItem Content="DXVA 2" Tag="DXVA2" />
                            <ComboBoxItem Content="关闭硬件解码" Tag="Disabled" />
                        </ComboBox>
                        <TextBlock Grid.Row="2" Text="视频输出方式" Style="{StaticResource SettingLabelStyle}" />
                        <ComboBox x:Name="VideoOutputCombo" Grid.Row="2" Grid.Column="1" Width="300" HorizontalAlignment="Left">
                            <ComboBoxItem Content="自动（推荐）" Tag="Auto" />
                            <ComboBoxItem Content="Direct3D 11" Tag="Direct3D11" />
                            <ComboBoxItem Content="Direct3D 9" Tag="Direct3D9" />
                            <ComboBoxItem Content="OpenGL" Tag="OpenGL" />
                        </ComboBox>
                        <TextBlock Grid.Row="3" Text="默认音频可视化" Style="{StaticResource SettingLabelStyle}" />
                        <ComboBox x:Name="VisualizationModeCombo" Grid.Row="3" Grid.Column="1" Width="300" HorizontalAlignment="Left">
                            <ComboBoxItem Content="关闭" Tag="Off" />
                            <ComboBoxItem Content="频谱" Tag="Spectrum" />
                            <ComboBoxItem Content="频谱仪" Tag="Spectrometer" />
                            <ComboBoxItem Content="波形" Tag="Scope" />
                        </ComboBox>
                        <TextBlock Grid.Row="4" Text="播放器画面字幕" Style="{StaticResource SettingLabelStyle}" />
                        <CheckBox x:Name="InPlayerSubtitlesCheckBox" Grid.Row="4" Grid.Column="1"
                                  Content="显示原文和中文翻译" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="5" Grid.ColumnSpan="2"
                                   Text="出现第三方音效驱动冲突时优先使用 DirectSound；音频设备、音轨、字幕轨与播放速度仍可在主界面的“媒体”页切换。"
                                   Style="{StaticResource HintStyle}" Margin="0,14,0,0" />
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="桌面歌词">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,22">
                        <TextBlock Text="桌面歌词" Style="{StaticResource SectionTitleStyle}" />
                        <WrapPanel Margin="0,0,0,18">
                            <CheckBox x:Name="LyricsTopmostCheckBox" Content="总在最前" Margin="0,0,28,10" />
                            <CheckBox x:Name="ShowTranslationCheckBox" Content="显示外文翻译" Margin="0,0,28,10"
                                      Click="LyricsPreviewSetting_Changed" />
                            <CheckBox x:Name="LyricsLockedCheckBox" Content="锁定位置" Margin="0,0,28,10" />
                            <CheckBox x:Name="LyricsStrokeCheckBox" Content="启用描边" Margin="0,0,28,10"
                                      Click="LyricsPreviewSetting_Changed" />
                            <CheckBox x:Name="LyricsClickToActivateCheckBox" Content="专注模式：仅点击歌词后显示控制栏"
                                      Margin="0,0,28,10"
                                      ToolTip="开启后只有歌词文字可点击，其他区域鼠标穿透；点击歌词后才能操作控制栏，移出歌词窗口后自动恢复穿透" />
                        </WrapPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="字体" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="LyricsFontCombo" Grid.Column="1" Width="280" HorizontalAlignment="Left"
                                      IsEditable="True" IsTextSearchEnabled="True" SelectionChanged="LyricsPreviewSetting_Changed" />
                            <TextBlock Grid.Column="2" Text="字重" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="LyricsFontWeightCombo" Grid.Column="3" Width="190" HorizontalAlignment="Left"
                                      SelectionChanged="LyricsPreviewSetting_Changed">
                                <ComboBoxItem Content="标准" Tag="Normal" />
                                <ComboBoxItem Content="中等" Tag="Medium" />
                                <ComboBoxItem Content="半粗" Tag="SemiBold" />
                                <ComboBoxItem Content="粗体" Tag="Bold" />
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="原文字号" Style="{StaticResource SettingLabelStyle}" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="LyricsFontSizeSlider" Width="240" Minimum="12" Maximum="72" TickFrequency="1"
                                        IsSnapToTickEnabled="True" ValueChanged="LyricsFontSizeSlider_ValueChanged" />
                                <TextBlock x:Name="LyricsFontSizeText" Width="50" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="翻译字号（分行）" Style="{StaticResource SettingLabelStyle}" />
                            <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal">
                                <Slider x:Name="LyricsTranslationFontSizeSlider" Width="150" Minimum="10" Maximum="72"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="LyricsTranslationFontSizeSlider_ValueChanged" />
                                <TextBlock x:Name="LyricsTranslationFontSizeText" Width="42" Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Grid.Row="2" Text="显示布局" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="LyricsLayoutCombo" Grid.Row="2" Grid.Column="1" Width="190" HorizontalAlignment="Left"
                                      SelectionChanged="LyricsPreviewSetting_Changed">
                                <ComboBoxItem Content="原文与翻译分行" Tag="Stacked" />
                                <ComboBoxItem Content="原文与翻译单行" Tag="SingleLine" />
                            </ComboBox>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="对齐" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="LyricsAlignmentCombo" Grid.Row="2" Grid.Column="3" Width="190" HorizontalAlignment="Left"
                                      SelectionChanged="LyricsPreviewSetting_Changed">
                                <ComboBoxItem Content="居中" Tag="Center" />
                                <ComboBoxItem Content="左对齐" Tag="Left" />
                                <ComboBoxItem Content="右对齐" Tag="Right" />
                            </ComboBox>

                            <TextBlock Grid.Row="3" Text="配色方案" Style="{StaticResource SettingLabelStyle}" />
                            <ComboBox x:Name="LyricsColorCombo" Grid.Row="3" Grid.Column="1" Width="190" HorizontalAlignment="Left"
                                      SelectionChanged="LyricsPreviewSetting_Changed">
                                <ComboBoxItem Content="薄荷紫" Tag="MintPurple" />
                                <ComboBoxItem Content="经典白" Tag="Classic" />
                                <ComboBoxItem Content="高对比" Tag="HighContrast" />
                                <ComboBoxItem Content="自定义" Tag="Custom" />
                            </ComboBox>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="渐变" Style="{StaticResource SettingLabelStyle}" />
                            <CheckBox x:Name="LyricsGradientCheckBox" Grid.Row="3" Grid.Column="3" Content="使用上下渐变"
                                      Click="LyricsPreviewSetting_Changed" />

                            <TextBlock Grid.Row="4" Text="自定义颜色" Style="{StaticResource SettingLabelStyle}" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal">
                                <Button x:Name="PrimaryColorButton" Content="主色" Width="105" Margin="0,0,10,0"
                                        Click="PrimaryColorButton_Click" />
                                <Button x:Name="SecondaryColorButton" Content="副色" Width="105" Margin="0,0,10,0"
                                        Click="SecondaryColorButton_Click" />
                                <Button x:Name="StrokeColorButton" Content="描边色" Width="105" Margin="0,0,18,0"
                                        Click="StrokeColorButton_Click" />
                                <TextBlock Text="选择颜色后自动切换到“自定义”" VerticalAlignment="Center"
                                           Style="{StaticResource HintStyle}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="预览" FontWeight="SemiBold" Margin="0,20,0,10" />
                        <Border Background="#171B1A" CornerRadius="8" Height="126" Padding="20">
                            <StackPanel VerticalAlignment="Center">
                                <local:OutlinedTextBlock x:Name="LyricsPreviewOriginal" Text="夜空中的旋律正在流动"
                                           FontSize="26" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <local:OutlinedTextBlock x:Name="LyricsPreviewTranslation"
                                           Text="The melody is flowing through the night" FontSize="17"
                                           TextAlignment="Center" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="52" />
                                <RowDefinition Height="52" />
                                <RowDefinition Height="52" />
                                <RowDefinition Height="58" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="交互背景透明度" Style="{StaticResource SettingLabelStyle}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="LyricsOpacitySlider" Width="300" Minimum="0.1" Maximum="0.95" TickFrequency="0.05"
                                        IsSnapToTickEnabled="True" ValueChanged="LyricsOpacitySlider_ValueChanged" />
                                <TextBlock x:Name="LyricsOpacityText" Width="60" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="窗口宽度" Style="{StaticResource SettingLabelStyle}" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="LyricsWidthSlider" Width="300" Minimum="480" Maximum="1600" TickFrequency="40"
                                        IsSnapToTickEnabled="True" ValueChanged="LyricsWidthSlider_ValueChanged" />
                                <TextBlock x:Name="LyricsWidthText" Width="80" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="歌词时间偏移" Style="{StaticResource SettingLabelStyle}" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="LyricsOffsetSlider" Width="300" Minimum="-5" Maximum="5" TickFrequency="0.5"
                                        IsSnapToTickEnabled="True" ValueChanged="LyricsOffsetSlider_ValueChanged" />
                                <TextBlock x:Name="LyricsOffsetText" Width="80" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Grid.Row="3" Text="窗口位置" Style="{StaticResource SettingLabelStyle}" />
                            <Button Grid.Row="3" Grid.Column="1" Content="重置桌面歌词位置" Width="180" HorizontalAlignment="Left"
                                    Click="ResetLyricsPositionButton_Click" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="曲库">
                <Grid Margin="28,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="音乐文件夹" Style="{StaticResource SectionTitleStyle}" />
                    <ListBox x:Name="LibraryFoldersList" Grid.Row="1" MinHeight="300" BorderBrush="{StaticResource LineBrush}"
                             Background="White" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,16">
                        <Button Content="添加文件夹" Margin="0,0,8,0" Click="AddLibraryFolderButton_Click" />
                        <Button Content="移除所选" Click="RemoveLibraryFolderButton_Click" />
                    </StackPanel>
                    <CheckBox x:Name="ScanOnStartupCheckBox" Grid.Row="3" Content="程序启动时重新扫描曲库" />
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Button Content="保存并重新扫描" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Click="SaveAndRescanButton_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="取消" Width="88" Margin="0,0,8,0" IsCancel="True" />
                    <Button Content="保存" Width="88" Style="{StaticResource AccentButtonStyle}" IsDefault="True"
                            Click="SaveButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
