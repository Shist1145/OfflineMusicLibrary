<Window x:Class="OfflineMusicLibrary.DesktopLyricsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OfflineMusicLibrary"
        Title="桌面歌词" Width="760" Height="154" MinWidth="480" MinHeight="124"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseEnter="Window_MouseEnter" MouseLeave="Window_MouseLeave"
        LocationChanged="Window_LocationChanged">
    <Window.Resources>
        <Style x:Key="LyricToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#35FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#55FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
            CornerRadius="6" Padding="14,7">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="上一首" Click="PreviousButton_Click" />
                <MenuItem Header="播放 / 暂停" Click="PlayPauseButton_Click" />
                <MenuItem Header="下一首" Click="NextButton_Click" />
                <Separator />
                <MenuItem x:Name="LockMenuItem" Header="锁定位置" IsCheckable="True" Click="LockMenuItem_Click" />
                <MenuItem Header="歌词设置" Click="SettingsButton_Click" />
                <Separator />
                <MenuItem Header="关闭桌面歌词" Click="CloseButton_Click" />
            </ContextMenu>
        </Border.ContextMenu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="Toolbar" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Top" Visibility="Collapsed">
                <Button Content="♪" Style="{StaticResource LyricToolbarButton}" ToolTip="打开主窗口" Click="ActivateMainButton_Click" />
                <Button Content="−0.5s" Style="{StaticResource LyricToolbarButton}" ToolTip="歌词提前 0.5 秒"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Click="OffsetEarlierButton_Click" />
                <Button Content="+0.5s" Style="{StaticResource LyricToolbarButton}" ToolTip="歌词延后 0.5 秒"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Click="OffsetLaterButton_Click" />
                <Button Content="|◀" Style="{StaticResource LyricToolbarButton}" ToolTip="上一首" Click="PreviousButton_Click" />
                <Button x:Name="ToolbarPlayPauseButton" Content="▶" Style="{StaticResource LyricToolbarButton}"
                        ToolTip="播放 / 暂停" Click="PlayPauseButton_Click" />
                <Button Content="▶|" Style="{StaticResource LyricToolbarButton}" ToolTip="下一首" Click="NextButton_Click" />
                <Button Content="⚙" Style="{StaticResource LyricToolbarButton}" ToolTip="设置" Click="SettingsButton_Click" />
                <Button x:Name="LockButton" Content="□" Style="{StaticResource LyricToolbarButton}"
                        ToolTip="锁定位置" Click="LockButton_Click" />
                <Button Content="×" Style="{StaticResource LyricToolbarButton}" ToolTip="关闭桌面歌词" Click="CloseButton_Click" />
                <TextBlock x:Name="OffsetText" Foreground="#C8FFFFFF" FontFamily="Microsoft YaHei UI" FontSize="11"
                           Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <local:OutlinedTextBlock x:Name="OriginalText" Grid.Row="1" Text="桌面歌词" FontFamily="Microsoft YaHei UI"
                       FontSize="25" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="NoWrap"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <local:OutlinedTextBlock x:Name="TranslationText" Grid.Row="2" Text="" FontFamily="Microsoft YaHei UI"
                       FontSize="17" TextAlignment="Center" TextWrapping="NoWrap" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</Window>
