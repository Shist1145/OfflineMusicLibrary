<Window x:Class="OfflineMusicLibrary.TrackDestinationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加到…" Width="620" Height="610" MinWidth="540" MinHeight="520"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="选择歌曲去向" FontSize="21" FontWeight="SemiBold" />
            <TextBlock x:Name="SelectionSummaryText" Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,5,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="7" Padding="14,12">
                <CheckBox x:Name="PlayNextCheckBox" VerticalContentAlignment="Center">
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="下一首播放" FontWeight="SemiBold" />
                        <TextBlock Text="插入到当前歌曲之后" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,3,0,0" />
                    </StackPanel>
                </CheckBox>
            </Border>
            <Border Grid.Column="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="7" Padding="14,12">
                <CheckBox x:Name="AppendQueueCheckBox" VerticalContentAlignment="Center">
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="添加到播放队列" FontWeight="SemiBold" />
                        <TextBlock Text="追加到当前队列末尾" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,3,0,0" />
                    </StackPanel>
                </CheckBox>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,9">
            <TextBlock Text="保存到歌单（可多选）" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBox x:Name="PlaylistSearchBox" Width="220" Height="34" HorizontalAlignment="Right"
                     Padding="10,5" ToolTip="搜索歌单名称、简介或标签" TextChanged="PlaylistSearchBox_TextChanged" />
        </Grid>

        <Border Grid.Row="3" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="7">
            <Grid>
                <TextBlock x:Name="EmptyPlaylistText" Text="还没有歌单，可在下方直接创建一个。"
                           Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Visibility="Collapsed" />
                <ListBox x:Name="PlaylistOptionsList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalContentAlignment="Center">
                                <Grid Margin="8,2,4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="38" Height="38">
                                        <Border Background="#E3E9E6" CornerRadius="4">
                                            <TextBlock Text="♫" FontSize="17" Foreground="#9AA9A3"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="4" ClipToBounds="True">
                                            <Image Source="{Binding Playlist.CoverThumbnail}" Stretch="UniformToFill" />
                                        </Border>
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Playlist.Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding Playlist.CountText, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding Playlist.DescriptionPreview, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="新建歌单" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox x:Name="NewPlaylistNameBox" Grid.Column="1" Height="36" VerticalContentAlignment="Center"
                     ToolTip="留空则不创建；输入名称后会同时把歌曲加入新歌单" />
        </Grid>

        <Grid Grid.Row="5" Margin="0,18,0,0">
            <TextBlock x:Name="ValidationText" Foreground="{StaticResource WarmBrush}" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="82" Margin="0,0,9,0" IsCancel="True" />
                <Button Content="完成" Width="90" Style="{StaticResource AccentButtonStyle}" IsDefault="True"
                        Click="ConfirmButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
