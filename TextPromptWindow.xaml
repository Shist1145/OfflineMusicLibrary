<Window x:Class="OfflineMusicLibrary.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Width="430" Height="190" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" Text="请输入内容" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
        <TextBox x:Name="ValueTextBox" Grid.Row="1" Height="38" VerticalContentAlignment="Center" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="取消" Width="76" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="确定" Width="76" Style="{StaticResource AccentButtonStyle}" IsDefault="True" Click="ConfirmButton_Click" />
        </StackPanel>
    </Grid>
</Window>
